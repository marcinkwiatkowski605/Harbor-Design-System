{
  "name": "harbor-design-system",
  "version": "1.3.0",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "cd ./packages/harbor-storybook && npm run storybook",
    "build:tokens": "cd ./packages/harbor-tokens && npm run build:tokens",
    "build:storybook": "cd ./packages/harbor-storybook && npm run build-storybook",
    "build:llms": "node scripts/build-llms-docs.mjs",
    "audit:tokens": "node scripts/audit-tokens.mjs",
    "test:storybook:ci": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"http-server packages/harbor-storybook/storybook-static --port 6006 --silent\" \"wait-on tcp:6006 && npm run test-storybook --workspace=@harbor/storybook -- --url http://localhost:6006\""
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "concurrently": "^10.0.3",
    "http-server": "^14.1.1",
    "semantic-release": "^25.0.5",
    "wait-on": "^9.0.10"
  }
}
